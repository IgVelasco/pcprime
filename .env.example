# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional: ID of a specific text channel for nightly messages.
# If left blank, PCPrime uses the server's System Messages channel,
# or falls back to the first text channel it can write to.
# Right-click the channel in Discord (with Developer Mode on) → Copy ID
ANNOUNCE_CHANNEL_ID=

# Optional: restrict the bot to a single server (guild ID).
# Leave blank or remove the line to operate on all servers the bot is in.
GUILD_ID=
